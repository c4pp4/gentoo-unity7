From 1cb80a7090cc0500300d46a538febc7743f0a641 Mon Sep 17 00:00:00 2001
From: c4pp4
Date: Tue, 24 Feb 2026 02:29:02 +0100
Subject: [PATCH 1/1] Remove light edges in menu corners

Signed-off-by: c4pp4
---
 gtk/src/default/gtk-3.0/_common.scss | 10 ----------
 gtk/src/default/gtk-3.0/_tweaks.scss |  6 ------
 2 files changed, 16 deletions(-)

diff --git a/gtk/src/default/gtk-3.0/_common.scss b/gtk/src/default/gtk-3.0/_common.scss
index 5724773..c73c5d0 100644
--- a/gtk/src/default/gtk-3.0/_common.scss
+++ b/gtk/src/default/gtk-3.0/_common.scss
@@ -2174,14 +2174,6 @@ menubar,
     min-height: 16px;
     padding: 4px 8px;
 
-    // remove padding and rounding from menubar submenus
-    menu {
-      &:dir(rtl), &:dir(ltr) { // specificity bump
-        border-radius: 0;
-        padding: 0;
-      }
-    }
-
     &:hover { //Seems like it :hover even with keyboard focus
       box-shadow: inset 0 -3px $selected_bg_color;
       color: $link_color;
@@ -4601,8 +4593,6 @@ decoration {
 
   .csd.popup & {
     border-radius: $menu_radius;
-    box-shadow: 0 1px 2px transparentize(black, 0.8),
-                0 0 0 1px transparentize($_wm_border, 0.1);
   }
 
   tooltip.csd & {
diff --git a/gtk/src/default/gtk-3.0/_tweaks.scss b/gtk/src/default/gtk-3.0/_tweaks.scss
index 5a3af91..85d8698 100644
--- a/gtk/src/default/gtk-3.0/_tweaks.scss
+++ b/gtk/src/default/gtk-3.0/_tweaks.scss
@@ -316,12 +316,6 @@ levelbar {
 // Strengthen the menu shadows
 // And lighten up the dark shell menu/popover border to increase visibility
 $_dark_theme_outer_menu_border: lighten(desaturate($base_color, 100%), 14%);
-decoration {
-  .csd.popup & {
-    box-shadow: 0 1px 2px 1px transparentize(black, if($variant=='light', 0.7, 0.6)),
-                0 0 0 1px if($variant=='light', transparentize(black, 0.77), $_dark_theme_outer_menu_border);
-  }
-}
 @if $variant=='dark' {
   menu separator {
     background-color: $_dark_theme_outer_menu_border;
-- 
2.52.0

