From fa88fc868174bf9a7c0d62f0aca4114a7beedc01 Mon Sep 17 00:00:00 2001
From: c4pp4
Date: Tue, 14 Apr 2026 19:54:22 +0200
Subject: [PATCH 1/1] Draw shadow around GTK4/libadwaita app window

Signed-off-by: c4pp4
---
 decorations/DecoratedWindow.cpp | 11 +++++++++++
 unity-shared/CompizUtils.cpp    |  8 +++++++-
 2 files changed, 18 insertions(+), 1 deletion(-)

diff --git a/decorations/DecoratedWindow.cpp b/decorations/DecoratedWindow.cpp
index 21f192c..4ac588b 100644
--- a/decorations/DecoratedWindow.cpp
+++ b/decorations/DecoratedWindow.cpp
@@ -713,6 +713,17 @@ void Window::Impl::ComputeGenericShadowQuads()
       win_region.shrink(client_borders_.left + client_borders_.right, client_borders_.top + client_borders_.bottom);
       win_region.translate(client_borders_.left - client_borders_.right, client_borders_.top - client_borders_.bottom);
     }
+    else
+    {
+      bool is_normal_app_window = (win_->type() & (CompWindowTypeNormalMask | 
+                                                   CompWindowTypeDialogMask | 
+                                                   CompWindowTypeModalDialogMask));
+
+      if (is_normal_app_window && win_->alpha() && !(win_->mwmDecor() & MwmDecorBorder))
+      {
+        win_region.shrink(30, 30);
+      }
+    }
 
     quads[Quads::Pos::TOP_LEFT].region = CompRegion(quads[Quads::Pos::TOP_LEFT].box) - win_region;
     quads[Quads::Pos::TOP_RIGHT].region = CompRegion(quads[Quads::Pos::TOP_RIGHT].box) - win_region;
diff --git a/unity-shared/CompizUtils.cpp b/unity-shared/CompizUtils.cpp
index bbc9ae9..101a36b 100644
--- a/unity-shared/CompizUtils.cpp
+++ b/unity-shared/CompizUtils.cpp
@@ -228,8 +228,14 @@ unsigned WindowDecorationElements(CompWindow* win, WindowFilter wf)
       elements |= DecorationElement::BORDER;
   }
 
-  if (alpha && !(elements & DecorationElement::BORDER) && !(win->mwmDecor() & MwmDecorBorder))
+  bool is_normal_app_window = (win->type() & (CompWindowTypeNormalMask | 
+                                              CompWindowTypeDialogMask | 
+                                              CompWindowTypeModalDialogMask));
+
+  if (!is_normal_app_window && alpha && !(elements & DecorationElement::BORDER) && !(win->mwmDecor() & MwmDecorBorder))
+  {
     elements &= ~DecorationElement::SHADOW;
+  }
 
   return elements;
 }
-- 
