 	QTDBUSMOCK_PUBLIC_HEADERS
 	"${CMAKE_CURRENT_BINARY_DIR}/config.h"
+	"${CMAKE_CURRENT_BINARY_DIR}/libqtdbusmock/qtdbusmock_export.h"
 	DBusMock.h
 	DeclareMetatypes.h
 	ExportInterfaces.h
@@ -199,6 +200,14 @@ add_library(
 	${QTDBUSMOCK_SRC}
 )
 
+file(MAKE_DIRECTORY "${CMAKE_CURRENT_BINARY_DIR}/libqtdbusmock")
+
+generate_export_header(
+	qtdbusmock
+	BASE_NAME qtdbusmock
+	EXPORT_FILE_NAME "${CMAKE_CURRENT_BINARY_DIR}/libqtdbusmock/qtdbusmock_export.h"
+)
+
 target_link_libraries(
     qtdbusmock
     Qt::Core
