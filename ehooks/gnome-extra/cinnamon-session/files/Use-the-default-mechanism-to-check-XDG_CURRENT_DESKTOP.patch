From f6dfbfc345fa4825f20037c623c51f93fab97e8c Mon Sep 17 00:00:00 2001
From: c4pp4
Date: Tue, 19 May 2026 16:47:12 +0200
Subject: [PATCH 1/1] Use the default mechanism to check XDG_CURRENT_DESKTOP

Signed-off-by: c4pp4
---
 cinnamon-session/csm-autostart-app.c | 4 +---
 1 file changed, 1 insertion(+), 3 deletions(-)

diff --git a/cinnamon-session/csm-autostart-app.c b/cinnamon-session/csm-autostart-app.c
index 0b08f05..e97d03b 100644
--- a/cinnamon-session/csm-autostart-app.c
+++ b/cinnamon-session/csm-autostart-app.c
@@ -142,9 +142,7 @@ is_disabled (CsmApp *app)
         g_desktop_app_info_set_desktop_env (current_desktop);
         if (current_desktop != NULL &&
             !g_desktop_app_info_get_show_in (G_DESKTOP_APP_INFO (priv->app_info),
-                                             "GNOME") &&
-            !g_desktop_app_info_get_show_in (G_DESKTOP_APP_INFO (priv->app_info),
-                                             current_desktop)) {
+                                             NULL)) {
                         g_debug ("app %s not for %s",
                                  csm_app_peek_id (app), current_desktop);
                 return TRUE;
-- 
