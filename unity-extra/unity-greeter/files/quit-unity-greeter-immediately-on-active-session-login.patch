From 63f14098d9dd3d7049e974915f898ba0a039d20a Mon Sep 17 00:00:00 2001
From: c4pp4
Date: Mon, 25 May 2026 20:51:54 +0200
Subject: [PATCH 1/1] Quit unity-greeter immediately on active session login

In certain cases, when logging in an already active session,
unity-greeter may remain running after session start completes.
This leads to the greeter process not exiting cleanly.

Signed-off-by: c4pp4
---
 src/greeter-list.vala | 6 ++++++
 1 file changed, 6 insertions(+)

diff --git a/src/greeter-list.vala b/src/greeter-list.vala
index cc397d6..9c975c8 100644
--- a/src/greeter-list.vala
+++ b/src/greeter-list.vala
@@ -926,6 +926,12 @@ public abstract class GreeterList : FadableBox
         /* Set the background */
         background.draw_grid = false;
         background.queue_draw ();
+
+        var userbox = selected_entry as UserPromptBox;
+        if (userbox != null && userbox.is_active) {
+            debug ("Session started successfully. User %s has an active session - exiting greeter.", userbox.id);
+            Posix.exit (Posix.EXIT_SUCCESS);
+        }
     }
 
     public void login_complete ()
-- 
2.53.0

